NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Optional: Google Sign-In. Same value as backend GOOGLE_CLIENT_ID.
# Get from https://console.cloud.google.com/apis/credentials (OAuth 2.0 Client ID, Web application)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional: Google Fonts API key for the font family list in the Design panel (Text style).
# Enable "Google Fonts Developer API" at https://console.cloud.google.com/apis/library, then create an API key.
NEXT_PUBLIC_GOOGLE_FONTS_API_KEY=
